#八比特音
function kards:guns/ex_g36k/note
execute if score @s Note_Pitch matches ..0 run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 1 0.1
# execute if score @s Note_Pitch matches 1 run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 1.0594630943592952645618252949463 0.1
execute if score @s Note_Pitch matches 1 run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 1.1224620483093729814335330496792 0.1
# execute if score @s Note_Pitch matches 3 run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 1.1892071150027210667174999705605 0.1
execute if score @s Note_Pitch matches 2 run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 1.2599210498948731647672106072782 0.1
execute if score @s Note_Pitch matches 3 run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 1.3348398541700343648308318811845 0.1
# execute if score @s Note_Pitch matches 6 run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 1.4142135623730950488016887242097 0.1
execute if score @s Note_Pitch matches 4 run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 1.4983070768766814987992807320298 0.1
# execute if score @s Note_Pitch matches 8 run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 1.5874010519681994747517056392723 0.1
execute if score @s Note_Pitch matches 5 run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 1.6817928305074290860622509524664 0.1
# execute if score @s Note_Pitch matches 10 run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 1.781797436280678609480452411181 0.1
execute if score @s Note_Pitch matches 6 run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 1.8877486253633869932838263133351 0.1
execute if score @s Note_Pitch matches 7.. run playsound minecraft:block.note_block.bit player @a ~ ~ ~ 1 2 0.1

