execute store result score @s wuxiuzhihuo_ranshi run data get entity @s SelectedItem.components."minecraft:custom_data".ranshi
execute store result score @s wuxiuzhihuo_xinzhi run data get entity @s SelectedItem.components."minecraft:custom_data".xinzhi

