            "type": "minecraft:plain_message",
            "contents": ["",{"color":"#CE9178","text":"-----神器特殊效果详情-----"},"\n",{"color":"white","text":"[雷击]"},"\n",{"color":"gold","text":"投掷攻击"},{"color":"gray","text":"时于目标处"},{"color":"gold","text":"召唤闪电"},{"color":"gray","text":"令目标"},{"color":"gold","text":"眩晕0.5s"},"\n",{"color":"gray","text":"并对其范围2.5格敌人造成"},{"color":"gold","text":"1.5♥真实伤害"},"\n",{"color":"white","text":"[制裁]"},"\n",{"color":"gold","text":"攻击"},{"color":"gray","text":"时额外对目标范围5格内敌对生物造成"},{"color":"gold","text":"3.5♥真实伤害"},"\n",{"color":"dark_aqua","text":"CD:5s"},"\n",{"color":"dark_gray","text":"“自私的神遗落于世的权柄,"},"\n",{"color":"dark_gray","text":"只用一掷,便能划破风暴和人怨."},"\n",{"color":"dark_gray","text":"渎神的黄金时代到来后,"},"\n",{"color":"dark_gray","text":"无可容忍的众人不再肩负神谕."},"\n",{"color":"dark_gray","text":"部分序神相与其勾结,"},"\n",{"color":"dark_gray","text":"以直面主神的机会,换取新时代的地位."},"\n",{"color":"dark_gray","text":"于是众神的神怒不再遏制,在天上展开厮杀,"},"\n",{"color":"dark_gray","text":"天空蒙乌,雨水猩红,日失其晖,"},"\n",{"color":"dark_gray","text":"最后只余混杂的尸骸和藏宝."},"\n",{"color":"dark_gray","text":"可活到了新世界的神,也未受众人供奉,"},"\n",{"color":"dark_gray","text":"当软弱展露出来的一刻,便已再无神性可言.”"},"\n\n",{"color":"gray","text":"在主手时："},"\n",{"color":"dark_green","text":" 12 攻击伤害"},"\n",{"color":"dark_green","text":" 1.1 攻击速度"}],
